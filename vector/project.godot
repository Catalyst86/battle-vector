; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Vector"
config/description="Minimal vector-style PvP tower defense."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

GameConfig="*res://autoload/game_config_loader.gd"
Palette="*res://autoload/palette.gd"
Pseudo3D="*res://autoload/pseudo_3d.gd"
Router="*res://autoload/router.gd"
PlayerDeck="*res://autoload/player_deck.gd"
PlayerProfile="*res://autoload/player_profile.gd"
CurrentMatch="*res://autoload/current_match.gd"

[display]

window/size/viewport_width=360
window/size/viewport_height=780
window/size/window_width_override=402
window/size/window_height_override=873
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"
window/handheld/orientation=1

[input_devices]

pointing/emulate_mouse_from_touch=true
pointing/emulate_touch_from_mouse=true

[physics]

2d/default_gravity=0
common/enable_pause_aware_picking=true

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
anti_aliasing/quality/msaa_2d=2
environment/defaults/default_clear_color=Color(0.0235294, 0.0313726, 0.0431373, 1)
